# Function to process a single file (image or PDF)
process_file() {
    local FILE="$1"
    local CURRENT_LANG="$2"
    local OCR_OUTPUTS="$3"
    OPTIMAL_PSM=6
    
    # Check if both quality and language were manually specified
    if [[ "$USER_SPECIFIED_QUALITY" == "true" && "$USER_SPECIFIED_LANGUAGE" == "true" ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "⚡ Both quality (-q) and language (-l) specified - skipping all auto-detection for maximum speed"
            echo "📐 Using specified quality level: $QUALITY_THRESHOLD"
            echo "🌐 Using specified language: $LANGUAGE"
        fi
        # Map quality level to appropriate profile settings
        case "$QUALITY_THRESHOLD" in
            "1") OPTIMAL_SETTINGS="$FAST_PROFILE" ;;     # 200 DPI
            "2") OPTIMAL_SETTINGS="$STANDARD_PROFILE" ;; # 300 DPI
            "3") OPTIMAL_SETTINGS="$BALANCED_PROFILE" ;; # 450 DPI
            "4") OPTIMAL_SETTINGS="$HIGH_PROFILE" ;;     # 600 DPI
            "5") OPTIMAL_SETTINGS="$ULTRA_PROFILE" ;;    # 900 DPI
            *) OPTIMAL_SETTINGS="$STANDARD_PROFILE" ;;   # Default to 300 DPI
        esac
    elif [[ "$USER_SPECIFIED_QUALITY" == "true" ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "🔍 Quality level specified ($QUALITY_THRESHOLD) - skipping DPI testing"
            echo "🌐 Language auto-detection will be performed if needed"
        fi
        # Map quality level to appropriate profile settings
        case "$QUALITY_THRESHOLD" in
            "1") OPTIMAL_SETTINGS="$FAST_PROFILE" ;;     # 200 DPI
            "2") OPTIMAL_SETTINGS="$STANDARD_PROFILE" ;; # 300 DPI
            "3") OPTIMAL_SETTINGS="$BALANCED_PROFILE" ;; # 450 DPI
            "4") OPTIMAL_SETTINGS="$HIGH_PROFILE" ;;     # 600 DPI
            "5") OPTIMAL_SETTINGS="$ULTRA_PROFILE" ;;    # 900 DPI
            *) OPTIMAL_SETTINGS="$STANDARD_PROFILE" ;;   # Default to 300 DPI
        esac
    elif [[ "$USER_SPECIFIED_LANGUAGE" == "true" ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "🌐 Using specified language: $LANGUAGE"
            echo "📐 Using standard 300 DPI processing (use -q to optimize)"
        fi
        OPTIMAL_SETTINGS="$DEFAULT_DPI"
    else
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "🔍 Performing full auto-detection (language + DPI optimization)"
        fi
        # Set default quality level for auto-optimization (balanced)
        QUALITY_THRESHOLD="3"
        # Test quality on first page to determine optimal settings
        if ! test_first_page_quality "$FILE" "$CURRENT_LANG"; then
            echo "Warning: Quality test failed, using standard settings"
            OPTIMAL_SETTINGS="$DEFAULT_DPI"
        fi
    fi
    
    # Extract optimal settings
    local settings_array=($OPTIMAL_SETTINGS)
    local optimal_dpi=${settings_array[0]}
    local optimal_enhancements="${settings_array[@]:1}"
    
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo "🚀 Processing with optimal settings:"
        echo "   📐 Resolution: $optimal_dpi DPI"
        echo "   🔧 Enhancements: $optimal_enhancements"
        echo "   🌐 Language: $DETECTED_LANGUAGE"
        echo
    fi
    
    local is_pdf=0
    
    # Extract the filename without the extension
    FILENAME=$(basename "$FILE")
    FILENAME_WITHOUT_EXT="${FILENAME%.*}"
    
    # Check if file is PDF
    if [[ "$(echo "$FILE" | tr '[:upper:]' '[:lower:]')" =~ \.pdf$ ]]; then
        is_pdf=1
        echo "Processing PDF file: $FILENAME"
        # Create temporary directory for PDF pages
        local pdf_temp_dir=$(mktemp -d)
        # Convert PDF to images with optimal quality settings
        if [[ -n "$optimal_enhancements" ]]; then
            if ! magick -density $optimal_dpi "$FILE" $optimal_enhancements "$pdf_temp_dir/page-%04d.png"; then
                echo "Error: Failed to process PDF '$FILE'"
                rm -rf "$pdf_temp_dir"
                return 1
            fi
        else
            if ! magick -density $optimal_dpi "$FILE" "$pdf_temp_dir/page-%04d.png"; then
                echo "Error: Failed to process PDF '$FILE'"
                rm -rf "$pdf_temp_dir"
                return 1
            fi
        fi
        # Process each page
        local page_num=1
        for page in "$pdf_temp_dir"/page-*.png; do
            echo "Processing page $page_num..."
            process_single_image "$page" "$CURRENT_LANG" "$OCR_OUTPUTS" "${FILENAME_WITHOUT_EXT}_page${page_num}"
            ((page_num++))
        done
        rm -rf "$pdf_temp_dir"
        # After processing all PDF pages, combine the outputs
        combine_pdf_outputs "$FILENAME_WITHOUT_EXT" "$OCR_OUTPUTS"
        return 0
    fi
    
    # Process regular image
    process_single_image "$FILE" "$CURRENT_LANG" "$OCR_OUTPUTS" "$FILENAME_WITHOUT_EXT"
}

# Function to process a single image
process_single_image() {
    local FILE="$1"
    local CURRENT_LANG="$2"
    local OCR_OUTPUTS="$3"
    local OUTPUT_NAME="$4"
    
    # Create a temporary file with enhanced resolution and quality using optimal settings
    local TEMP_FILE=$(mktemp)
    if [[ -n "$optimal_enhancements" ]]; then
        if ! magick "$FILE" -density $optimal_dpi $optimal_enhancements "$TEMP_FILE" 2>/dev/null; then
            echo "Error: Failed to process '$FILE'. Not a valid image?"
            rm "$TEMP_FILE"
            return 1
        fi
    else
        if ! magick "$FILE" -density $optimal_dpi "$TEMP_FILE" 2>/dev/null; then
            echo "Error: Failed to process '$FILE'. Not a valid image?"
            rm "$TEMP_FILE"
            return 1
        fi
    fi

    # Try to detect language if user didn't specify one
    if [[ "$USER_SPECIFIED_LANGUAGE" != "true" ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo -n "Analyzing '$(basename "$FILE")' for language... "
        fi
        if detect_language "$TEMP_FILE"; then
            # Automatically use detected language
            CURRENT_LANG="script/$detected_script"
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "detected $detected_script, using it for OCR"
            fi
        else
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "could not detect script, using default ($LANGUAGE)"
            fi
        fi
    fi
    
    # Generate versioned output filename
    local base_output_name="${OCR_OUTPUTS}/ocr_${OUTPUT_NAME}"
    local versioned_output=$(get_versioned_filename "$base_output_name" "txt")
    local output_base=$(echo "$versioned_output" | sed 's/\.txt$//')
    
    # Perform OCR using tesseract with enhanced settings for better accuracy
    tesseract -l "$CURRENT_LANG" --psm $OPTIMAL_PSM --oem 3 -c preserve_interword_spaces=1 "$TEMP_FILE" "$output_base"
    # Check if tesseract executed successfully
    if [ $? -eq 0 ]; then
        output_file="$versioned_output"
        if [ -s "$output_file" ]; then
            echo "✓ OCR output for '$(basename "$FILE")' saved to $(basename "$output_file") ($(wc -l < "$output_file" | tr -d ' ') lines)"
            
            # Generate AI summary if requested
            if [ "$AI_SUMMARIZE" = "true" ]; then
                generate_ai_summary "$output_file" "$FILE" "$OCR_OUTPUTS" "$CURRENT_LANG"
            fi
        else
            echo "! OCR completed for '$(basename "$FILE")' but no text was found"
        fi
    else
        echo "✗ Error: OCR failed to process '$(basename "$FILE")'"
    fi
    
    # Remove the temporary file
    rm "$TEMP_FILE"
}

# Function to generate AI summarization of OCR text
generate_ai_summary() {
    local ocr_file="$1"
    local base_name="$2"
    local ocr_outputs_dir="$3"
    local current_lang="$4"
    
    if [ ! -s "$ocr_file" ]; then
        echo "! No text found in OCR output for AI summarization"
        return 1
    fi

    echo -n "🤖 Generating AI summary for '$(basename "$base_name")'... "
    
    # Create versioned AI summary filename
    local base_ai_name="${ocr_outputs_dir}/$(basename "$base_name" | sed 's/\.[^.]*$//')_ai"
    local ai_file=$(get_versioned_filename "$base_ai_name" "txt")
    
    # Read the OCR text
    local ocr_text=$(cat "$ocr_file")
    
    # Check if text is too short for meaningful summarization
    local word_count=$(echo "$ocr_text" | wc -w | tr -d ' ')
    if [ "$word_count" -lt 10 ]; then
        echo "skipped (too short: $word_count words)"
        return 1
    fi
    
    # Determine language for AI prompt
    local prompt_language="English"
    local summary_instruction="Please provide a concise summary of this document text in English."
    
    case "$current_lang" in
        *deu*|*ger*|script/Latin)
            if echo "$ocr_text" | grep -q -E "(der|die|das|und|ist|ein|eine|mit|für|von|zu|auf|an|in|bei|nach|vor|über|unter|zwischen|durch|gegen|ohne|um|seit|bis|während|wegen|trotz)"; then
                prompt_language="German"
                summary_instruction="Bitte erstellen Sie eine prägnante Zusammenfassung dieses Dokumenttextes auf Deutsch."
            fi
            ;;
        *fra*|*fre*)
            if echo "$ocr_text" | grep -q -E "(le|la|les|de|du|des|et|est|un|une|avec|pour|par|dans|sur|sous|entre|contre|sans|depuis|pendant|avant|après|vers)"; then
                prompt_language="French"
                summary_instruction="Veuillez fournir un résumé concis de ce texte de document en français."
            fi
            ;;
        *spa*)
            if echo "$ocr_text" | grep -q -E "(el|la|los|las|de|del|y|es|un|una|con|para|por|en|sobre|bajo|entre|contra|sin|desde|durante|antes|después|hacia)"; then
                prompt_language="Spanish"
                summary_instruction="Por favor, proporcione un resumen conciso de este texto del documento en español."
            fi
            ;;
        *ita*)
            if echo "$ocr_text" | grep -q -E "(il|la|lo|gli|le|di|del|della|e|è|un|una|con|per|da|in|su|sotto|tra|contro|senza|durante|prima|dopo|verso)"; then
                prompt_language="Italian"
                summary_instruction="Si prega di fornire un riassunto conciso di questo testo del documento in italiano."
            fi
            ;;
        *rus*)
            if echo "$ocr_text" | grep -q -E "(и|в|на|с|по|для|от|до|за|при|над|под|между|через|против|без|из|о|об|про|к|у|около)"; then
                prompt_language="Russian"
                summary_instruction="Пожалуйста, предоставьте краткое изложение этого текста документа на русском языке."
            fi
            ;;
    esac
    
    # Create language-aware AI prompt
    local ai_prompt="$summary_instruction Focus on the main topics, key information, and document type/purpose. Keep it under 200 words:

$ocr_text"
    
    # Call AI for summarization
    local ai_summary
    if [[ "$AI_OFFLINE_ONLY" == "true" ]]; then
        # Force Ollama-only mode (offline)
        if command -v ollama >/dev/null 2>&1; then
            ai_summary=$(echo "$ai_prompt" | ollama run llama3.2:1b 2>/dev/null | head -20)
        else
            echo "✗ Ollama not available (offline mode requested)"
            return 1
        fi
    elif command -v ollama >/dev/null 2>&1; then
        # Use Ollama as primary choice
        ai_summary=$(echo "$ai_prompt" | ollama run llama3.2:1b 2>/dev/null | head -20)
    else
        # Fallback to chat commands (ph, ph2, nls) for summarization
        local chat_cmd=$(find_chat_command)
        if [[ -n "$chat_cmd" ]]; then
            # Create temporary file with OCR text
            local temp_file=$(mktemp)
            echo "$ocr_text" > "$temp_file"
            
            # Use chat command with proper summarization instruction
            ai_summary=$("$chat_cmd" "$temp_file" "$summary_instruction Focus on main topics, key information, and document type/purpose. Keep it under 200 words." 2>/dev/null | head -20)
            rm "$temp_file"
        else
            # Final fallback to basic text analysis
            ai_summary="Document Summary:
Length: $(echo "$ocr_text" | wc -w | tr -d ' ') words
Lines: $(echo "$ocr_text" | wc -l | tr -d ' ') lines
Preview: $(echo "$ocr_text" | head -3 | tr '\n' ' ' | cut -c1-200)...
Key topics: $(echo "$ocr_text" | tr ' ' '\n' | sort | uniq -c | sort -nr | head -5 | awk '{print $2}' | tr '\n' ' ')"
        fi
    fi
    
    if [ -n "$ai_summary" ]; then
        # Save AI summary to file
        cat > "$ai_file" << EOF
AI SUMMARY - Generated by docr $(date)
Source: $(basename "$base_name")
Language: $prompt_language (OCR: $current_lang)
===========================================

$ai_summary

===========================================
Original OCR Text ($word_count words):

$ocr_text
EOF
        echo "✓ saved to $(basename "$ai_file")"
        return 0
    else
        echo "✗ AI summarization failed"
        return 1
    fi
}

