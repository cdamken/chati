            show_lang_help
            exit 0
            ;;
        -*)
            echo "Error: Unknown parameter '$1'"
            show_help
            exit 1
            ;;
        *)
            if [ -z "$TARGET_PATH" ]; then
                TARGET_PATH="$1"
