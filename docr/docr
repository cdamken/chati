# Function to combine multi-page outputs
combine_pdf_outputs() {
    local base_name="$1"
    local output_dir="$2"
    
    # Generate versioned filename for combined output
    local base_combined_file="${output_dir}/ocr_${base_name}"
    local versioned_combined_file=$(get_versioned_filename "$base_combined_file" "txt")
    local temp_file=$(mktemp)
    
    # Find all pages for this PDF
    local pages=("${output_dir}/ocr_${base_name}_page"*.txt)
    
    # Check if we found any pages
    if [ ${#pages[@]} -eq 0 ]; then
        echo "No pages found for $base_name"
        return 1
    fi
    
    # Add page markers and combine
    for page in "${pages[@]}"; do
        page_num=$(echo "$page" | grep -o 'page[0-9]*' | grep -o '[0-9]*')
        echo -e "\n=== Page $page_num ===\n" >> "$temp_file"
        cat "$page" >> "$temp_file"
        rm "$page"  # Remove individual page file
    done
    
    # Move combined file to final versioned location
    mv "$temp_file" "$versioned_combined_file"
    echo "✓ Combined output saved to $(basename "$versioned_combined_file")"
}

# Function to get next available filename with versioning
get_versioned_filename() {
    local base_file="$1"
    local extension="$2"
    
    # If original doesn't exist, use it
    if [ ! -f "${base_file}.${extension}" ]; then
        echo "${base_file}.${extension}"
        return
    fi
    
    # Find next available version number
    local counter=1
    while [ -f "${base_file}(${counter}).${extension}" ]; do
        counter=$((counter + 1))
    done
    
    echo "${base_file}(${counter}).${extension}"
}

