# Function to get language description
get_lang_description() {
    local lang_code="$1"
    local lang_file="$(dirname "$0")/.tesseract.lang.list"
    if [ -f "$lang_file" ]; then
        grep -E "\*\*${lang_code}\*\* -" "$lang_file" | 
        sed -E 's/^[0-9]+\. \*\*([^*]*)\*\* - (.*)/\2/'
    fi
}

# Function to detect script and language
detect_language() {
    local img="$1"
    # First try OSD to detect script
    local script_output
    script_output=$(tesseract "$img" stdout --psm 0 2>/dev/null)
    
    # Try to get the script name from the output
    detected_script=$(echo "$script_output" | grep "Script:" | cut -d' ' -f2)
    
    if [ -n "$detected_script" ]; then
        local desc
        desc=$(get_lang_description "script/$detected_script")
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            if [ -n "$desc" ]; then
                echo "Detected script: $detected_script ($desc)"
            else
                echo "Detected script: $detected_script"
            fi
        fi
        
        # If available, try the specific script detector
        if [ -f "/opt/homebrew/share/tessdata/script/$detected_script.traineddata" ]; then
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "Running detailed script detection..."
            fi
            return 0
        fi
    fi
    return 1
}

# Initialize language detection
DETECTED_LANGUAGE="$LANGUAGE"  # Will be updated during quality testing if auto-detection is used

# Process files based on arguments and extensions
for FILE in "${FILES[@]}"; do
    # Skip if file doesn't exist
    if [ ! -f "$FILE" ]; then
        echo "Error: File not found: $FILE"
        continue
    fi
    
    # Check if file extension is supported
    if [[ ! "$(echo "$FILE" | tr '[:upper:]' '[:lower:]')" =~ \.(${IMAGE_EXTENSIONS}|${PDF_EXTENSION})$ ]]; then
        echo "Error: Unsupported file type for '$FILE'. Supported extensions: ${IMAGE_EXTENSIONS}, ${PDF_EXTENSION}"
        continue
    fi
    
    # Process the file with detected language
    process_file "$FILE" "$DETECTED_LANGUAGE" "$OCR_OUTPUTS"
done

# Success message
echo "Done! OCR outputs saved in $OCR_OUTPUTS/"
