        echo "Score: $final_score (Words: $word_count × 2 = $word_score + Lines: $line_count × 3 = $line_score + Density: $char_density chars/line = $density_score)"
    fi
}

# Function to test OCR quality on first page
test_first_page_quality() {
    local file="$1"
    local lang="$2"
    local test_dir=$(mktemp -d)
    local best_profile=""
    local best_score=0
    local best_word_count=0
    
    # Arrays to store results for AI analysis (using indexed arrays as workaround)
    local profile_list=()
    local score_list=()
    local word_count_list=()
    local file_list=()
    
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo "🔍 Testing OCR quality on first page..."
    fi
    
    # Extract first page
    if [[ "$(echo "$file" | tr '[:upper:]' '[:lower:]')" =~ \.pdf$ ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "📋 Extracting first page from PDF..."
        fi
        if ! magick -density 300 "${file}[0]" "$test_dir/test_page.png" 2>/dev/null; then
            echo "❌ Failed to extract first page"
            rm -rf "$test_dir"
            return 1
        fi
    else
        # For images, just copy
        cp "$file" "$test_dir/test_page.png"
    fi
    
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo "🧪 Testing quality profiles:"
    else
        echo -n "🔍 Testing OCR quality... "
    fi
    
    # Language detection flag
    local language_detected=false
    local detected_language="$lang"
    
    # Test each profile
    for profile in $PROFILE_ORDER; do
        local settings=$(get_profile_settings "$profile")
        local dpi=$(echo $settings | awk '{print $1}')
        local enhancements=$(echo $settings | cut -d' ' -f2-)
        
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo -n "   ⚙️  Testing $profile ($dpi DPI)... "
        fi
        
        # Process with current profile
        local temp_image="$test_dir/enhanced_${profile}.png"
        
        # Apply image enhancements
        if [[ -n "$enhancements" ]]; then
            magick "$test_dir/test_page.png" -density $dpi $enhancements "$temp_image" 2>/dev/null || \
            magick "$test_dir/test_page.png" -density $dpi "$temp_image" 2>/dev/null
        else
            magick "$test_dir/test_page.png" -density $dpi "$temp_image" 2>/dev/null
        fi
        
        # Determine PSM (Page Segmentation Mode)
        local psm=6
        if [[ "$profile" == "columns" || "$profile" == "book" ]]; then
            psm=3 # Fully automatic page segmentation (better for multiple columns)
        fi
        
        # Run OCR with text output
        tesseract -l "$detected_language" --psm $psm --oem 3 \
                  -c preserve_interword_spaces=1 \
                  "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null || \
        tesseract -l "$detected_language" --psm $psm \
                  "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null
        
        # On first profile, detect language if needed (only if original language was 'eng')
        if [[ "$profile" == "ultra" && "$lang" == "eng" && "$language_detected" == false ]]; then
            if [[ -f "$test_dir/ocr_${profile}.txt" ]]; then
                local sample_text=$(head -15 "$test_dir/ocr_${profile}.txt" | tr '\n' ' ')
                
                if [[ "$VERBOSE_MODE" == "true" ]]; then
                    echo ""
                    echo "📝 OCR Sample for language detection: $(echo "$sample_text" | head -c 100)..."
                fi
                
                # Check for German banking terms first (with OCR error variants)
                if echo "$sample_text" | grep -qi "KONTO.*BERSICHT\|KONTO.*ÜBERSICHT\|ZAHLUNGSEINGANG\|ZAHLUNGSAUSGANG\|BESCHREIBUNG\|ECHTZEITUBERWEISUNG\|ECHTZEIT.*BERWEISUNG\|ÜBERWEISUNG\|UBERWEISUNG\|EMPF.*NGER\|VERWENDUNGSZWECK\|DATUM.*TYP\|SALDO.*EUR\|Trade.*Republic.*Bank\|EUR.*SALDO"; then
                    if [[ "$VERBOSE_MODE" == "true" ]]; then
                        echo ""
                        echo "🎯 Detected German banking terms, switching to German language..."
                    fi
                    detected_language="deu"
                    language_detected=true
                    # Re-run this profile with correct language
                    tesseract -l "$detected_language" --psm 6 --oem 3 \
                              -c preserve_interword_spaces=1 \
                              "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null || \
                    tesseract -l "$detected_language" --psm 6 \
                              "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null
                    echo -n "   ⚙️  Re-testing $profile with German... "
                elif [[ $(echo "$sample_text" | wc -w) -gt 10 ]]; then
                    echo ""
                    echo -n "🤖 Detecting language from OCR sample... "
                    local ai_detected_lang=$(detect_language_with_ai "$sample_text")
                    if [[ "$ai_detected_lang" != "eng" ]]; then
                        echo "detected: $ai_detected_lang"
                        detected_language="$ai_detected_lang"
                        language_detected=true
                        # Re-run this profile with correct language
                        tesseract -l "$detected_language" --psm 6 --oem 3 \
                                  -c preserve_interword_spaces=1 \
                                  "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null || \
                        tesseract -l "$detected_language" --psm 6 \
                                  "$temp_image" "$test_dir/ocr_${profile}" 2>/dev/null
                        echo -n "   ⚙️  Re-testing $profile with $detected_language... "
                    else
                        echo "confirmed English"
                        language_detected=true
                    fi
                fi
            fi
        fi
        
        # Calculate quality score with debug info
        local score_details=$(calculate_quality_score_debug "$test_dir/ocr_${profile}.txt")
        local score=$(echo "$score_details" | head -1)
        local word_count=$(echo "$score_details" | sed -n '2p')
        
        echo "$score_details" | tail -n +3
        
        # Store profile results for potential AI analysis
        profile_list+=("$profile")
        score_list+=("$score")
        word_count_list+=("$word_count")
        file_list+=("$test_dir/ocr_${profile}.txt")
        
        # Track best profile (prefer higher word count when scores are equal)
        if [[ $score -gt $best_score ]] || [[ $score -eq $best_score && $word_count -gt $best_word_count ]]; then
            best_score=$score
            best_profile=$profile
            best_word_count=$word_count
        fi
        
        # Continue testing all profiles (no early exit)
    done
    
    # Check if AI analysis could help with efficiency optimization
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo
        echo "⚡ Optimizing for efficiency while maintaining quality..."
    fi
    
    # Convert quality level to percentage threshold for AI analysis
    local ai_threshold
    case "$QUALITY_THRESHOLD" in
        "1") ai_threshold=30 ;;  # Low quality acceptable
        "2") ai_threshold=50 ;;  # Standard quality
        "3") ai_threshold=70 ;;  # Balanced quality
        "4") ai_threshold=85 ;;  # High quality
        "5") ai_threshold=95 ;;  # Maximum quality
        *) ai_threshold=70 ;;    # Default to balanced
    esac
    
    # Define quality threshold (minimum acceptable AI quality percentage)
    local min_quality_threshold=$ai_threshold
    local min_score_threshold=40  # Minimum basic score to consider
    
    # Test all profiles with AI to find the most efficient acceptable one
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo "🔍 Testing AI quality for all profiles to find optimal efficiency:"
    fi
    
    local efficient_profile=""
    local efficient_score=0
    local efficient_quality=0
    local profiles_tested=()
    local qualities_tested=()
    local scores_tested=()
    
    # Test profiles in order of efficiency (fastest to slowest)
    local efficiency_order=("fast" "standard" "balanced" "high" "ultra")
    
    for profile in "${efficiency_order[@]}"; do
        # Find this profile in our results
        local profile_idx=-1
        for i in "${!profile_list[@]}"; do
            if [[ "${profile_list[$i]}" == "$profile" ]]; then
                profile_idx=$i
                break
            fi
        done
        
        if [[ $profile_idx -eq -1 ]]; then
            continue  # Profile not found, skip
        fi
        
        local profile_score=${score_list[$profile_idx]}
        
        # Skip profiles with very low basic scores
        if [[ $profile_score -lt $min_score_threshold ]]; then
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "   ⏭️  Skipping $profile (score too low: $profile_score)"
            fi
            continue
        fi
        
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo -n "   🧠 Testing $profile (Score: $profile_score)... "
        fi
        local ai_quality=$(analyze_word_quality "${file_list[$profile_idx]}")
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "AI Quality: $ai_quality%"
        fi
        
        profiles_tested+=("$profile")
        qualities_tested+=("$ai_quality")
        scores_tested+=("$profile_score")
        
        # If this profile meets our quality threshold, use it (since we're testing in efficiency order)
        if [[ $ai_quality -ge $min_quality_threshold ]]; then
            efficient_profile=$profile
            efficient_score=$profile_score
            efficient_quality=$ai_quality
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "   ✅ $profile meets quality threshold ($ai_quality% ≥ $min_quality_threshold%) - selecting for efficiency!"
            fi
            break
        else
            if [[ "$VERBOSE_MODE" == "true" ]]; then
                echo "   ❌ $profile below threshold ($ai_quality% < $min_quality_threshold%)"
            fi
        fi
    done
    
    # If no profile meets the threshold, use the one with highest AI quality
    if [[ -z "$efficient_profile" ]]; then
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "   ⚠️  No profile meets quality threshold, selecting best available quality:"
        fi
        local best_ai_quality=0
        for i in "${!profiles_tested[@]}"; do
            if [[ ${qualities_tested[$i]} -gt $best_ai_quality ]]; then
                best_ai_quality=${qualities_tested[$i]}
                efficient_profile=${profiles_tested[$i]}
                efficient_quality=$best_ai_quality
                # Find score for this profile
                for j in "${!profile_list[@]}"; do
                    if [[ "${profile_list[$j]}" == "$efficient_profile" ]]; then
                        efficient_score=${score_list[$j]}
                        break
                    fi
                done
            fi
        done
        if [[ "$VERBOSE_MODE" == "true" ]]; then
            echo "   🎯 Selected $efficient_profile (best available: $efficient_quality%)"
        fi
    fi
    
    # Update final selection
    best_profile=$efficient_profile
    best_score=$efficient_score
    
    if [[ "$VERBOSE_MODE" == "true" ]]; then
        echo
        echo "🎯 Efficiency-optimized selection: $best_profile"
        echo "📊 Quality: $efficient_quality% AI quality, Score: $best_score"
        
        # Show efficiency savings
        case "$best_profile" in
            "fast") echo "💨 Maximum efficiency: 200 DPI (fastest processing)" ;;
            "standard") echo "⚡ High efficiency: 300 DPI (fast processing)" ;;
            "balanced") echo "⚖️  Balanced efficiency: 450 DPI (moderate processing)" ;;
            "high") echo "🔍 Lower efficiency: 600 DPI (slower processing)" ;;
            "ultra") echo "🐌 Minimum efficiency: 900 DPI (slowest processing)" ;;
        esac
        echo "📊 Selected settings: $(get_profile_settings "$best_profile")"
    fi
    
    # Store results in global variables
    OPTIMAL_PROFILE=$best_profile
    OPTIMAL_SETTINGS=$(get_profile_settings "$best_profile")
    OPTIMAL_PSM=6
    if [[ "$best_profile" == "columns" || "$best_profile" == "book" ]]; then
        OPTIMAL_PSM=3
    fi
    DETECTED_LANGUAGE=$detected_language
    
    rm -rf "$test_dir"
    return 0
}

