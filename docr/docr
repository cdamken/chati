# Description:
#   Advanced document processing tool that combines OCR (Optical Character
#   Recognition) with chat capabilities. Processes PDFs, images, and graphs,
#   extracts text content, and enables intelligent conversation about the
#   document contents.
#
# Features:
#   - PDF processing and conversion
#   - Image OCR with Tesseract
#   - Multi-language support
#   - Graph and chart processing
#   - Automatic language detection
#   - Integration with chat backends
#
# Usage:
#   ./graph_pdf_ocr file.pdf           # Process PDF
#   ./graph_pdf_ocr image.png          # Process image
#   ./graph_pdf_ocr -l eng file.jpg    # Specify language
#   ./graph_pdf_ocr -h                 # Show help
#
# Dependencies:
#   - tesseract (brew install tesseract tesseract-lang)
#   - imagemagick (brew install imagemagick)
#   - ghostscript (for PDF processing)
#   - One of: ph, nls, or ola backends
#
# Related Files:
#   - OCR_OUTPUTS/: Directory for processed files
#   - All chat backends (ph, nls, ola)
#==============================================================================

# Scoring weights
WORD_COUNT_WEIGHT=0.4
CONFIDENCE_WEIGHT=0.3
CHAR_DENSITY_WEIGHT=0.2
ERROR_RATE_WEIGHT=0.1

# Quality test profiles
ULTRA_PROFILE="900 -sharpen 0x1.5 -contrast-stretch 0.1x0.05% -enhance"
HIGH_PROFILE="600 -sharpen 0x1.0 -contrast-stretch 0.15x0.05%"
CLEAN_PROFILE="600 -colorspace Gray -level 25%,75% -sharpen 0x1.0"
SHADOW_PROFILE="450 -colorspace Gray -negate -lat 25x25+10% -negate -sharpen 0x1.0"
BOOK_PROFILE="450 -colorspace Gray -negate -lat 20x20+10% -negate -sharpen 0x1.0"
COLUMNS_PROFILE="450 -sharpen 0x1.0"
BALANCED_PROFILE="450 -sharpen 0x0.8 -contrast-stretch 0.2x0.1%"
STANDARD_PROFILE="300 -sharpen 0x0.5"
FAST_PROFILE="200"

PROFILE_ORDER="ultra high clean book shadow columns balanced standard fast"

# Function to get profile settings
get_profile_settings() {
    local profile="$1"
    case "$profile" in
        "ultra") echo "$ULTRA_PROFILE" ;;
        "high") echo "$HIGH_PROFILE" ;;
        "clean") echo "$CLEAN_PROFILE" ;;
        "book") echo "$BOOK_PROFILE" ;;
        "shadow") echo "$SHADOW_PROFILE" ;;
        "columns") echo "$COLUMNS_PROFILE" ;;
        "balanced") echo "$BALANCED_PROFILE" ;;
        "standard") echo "$STANDARD_PROFILE" ;;
        "fast") echo "$FAST_PROFILE" ;;
        *) echo "$STANDARD_PROFILE" ;;
    esac
}

# Function to find available AI chat command for word quality analysis
find_chat_command() {
    for cmd in "ola" "fph" "fph2" "fnls"; do
        # Check in current directory and PATH
        if [[ -x "./$cmd" ]]; then
            echo "./$cmd"
            return 0
        elif [[ -x "./ola_chat/$cmd" ]]; then
            echo "./ola_chat/$cmd"
            return 0
        elif [[ -x "$OLA_DIR/$cmd" ]]; then
            echo "$OLA_DIR/$cmd"
            return 0
        elif [[ -x "./ph_chat/$cmd" ]]; then
            echo "./ph_chat/$cmd"
            return 0
        elif [[ -x "./ph2_chat/$cmd" ]]; then
            echo "./ph2_chat/$cmd"
            return 0
        elif [[ -x "./nls_chat/$cmd" ]]; then
            echo "./nls_chat/$cmd"
            return 0
        elif command -v "$cmd" >/dev/null 2>&1; then
            echo "$cmd"
            return 0
        fi
    done
    return 1
}

# Function to analyze word quality using AI
analyze_word_quality() {
    local text_file="$1"
    local chat_cmd=$(find_chat_command)
    
    if [[ -z "$chat_cmd" || ! -f "$text_file" ]]; then
        echo "50"  # Default quality percentage
        return 1
    fi
    
    # Get sample of words for analysis
    local sample_words=$(head -10 "$text_file" | tr ' ' '\n' | grep -v '^$' | head -20 | tr '\n' ' ')
    
    if [[ -z "$sample_words" ]]; then
        echo "0"
        return 1
    fi
    
    # Create temporary file for AI analysis
    local temp_file=$(mktemp)
    cat > "$temp_file" << EOF
Analyze the quality of these OCR-extracted words and estimate what percentage are real, meaningful words (not gibberish, symbols, or OCR errors):

Sample words: $sample_words

Please respond with ONLY a number between 0-100 representing the percentage of quality words. For example:
- 95 = most words are real and correct
- 70 = many real words but some OCR errors  
- 30 = mostly gibberish with few real words
- 5 = almost all gibberish/errors

Respond with only the number:
EOF
    
    # Get AI assessment
    local quality_response=$("$chat_cmd" "$temp_file" 2>/dev/null | grep -o '[0-9][0-9]*' | head -1)
    
    rm "$temp_file"
    
    # Validate response (should be 0-100)
    if [[ "$quality_response" =~ ^[0-9]+$ ]] && [[ $quality_response -le 100 ]]; then
        echo "$quality_response"
        return 0
    else
        echo "50"  # Default if AI fails
        return 1
    fi
}

# Function to detect language using AI
detect_language_with_ai() {
    local sample_text="$1"
    local chat_cmd=$(find_chat_command)
    
    if [[ -z "$chat_cmd" ]]; then
        echo "eng"
        return 1
    fi
    
    echo -n "🤖 Analyzing text for language detection... "
    
    # Debug: Show what we're analyzing
    echo ""
    echo "   Sample: $(echo "$sample_text" | tr '\n' ' ' | cut -c1-100)..."
    
    # Create temporary file with sample text
    local temp_file=$(mktemp)
    cat > "$temp_file" << EOF
Document sample text for language detection:

$sample_text

Analyze this document text and determine the PRIMARY language of the content. Focus on the document's main language, not mixed-in foreign terms.

IMPORTANT: Look for these specific language indicators:
- German (deu): "DATUM, BESCHREIBUNG, ZAHLUNGSEINGANG, ZAHLUNGSAUSGANG, SALDO, Echtzeituberweisung" and compound words
- German currency: "€" with comma decimal separator (500,00 €)
- German banking terms: "SEPA", "Überweisung", compound words ending in "-ung, -eingang, -ausgang"

- French (fra): Articles "le, la, les", accents é,è,à,ç
- Spanish (spa): Articles "el, la, los", endings "-ción, -dad"  
- English (eng): Articles "the, a, an", typical English sentence structure

Even if there are English phrases mixed in (like "Incoming transfer"), determine the PRIMARY document language based on the majority of terms and document structure.

IMPORTANT German banking terms to recognize:
- DATUM, BESCHREIBUNG, ZAHLUNGSEINGANG, ZAHLUNGSAUSGANG, SALDO = German
- Echtzeituberweisung, Überweisung = German banking terms
- Currency format "500,00 €" = German/European format

If you see these German banking terms, respond with: deu
If mainly English terms, respond with: eng

Respond with ONLY the 3-letter code (deu, eng, fra, spa, etc.):
EOF
    
    # Use file chat command to analyze the text
    local ai_response=$("$chat_cmd" "$temp_file" 2>/dev/null | grep -o '\b[a-z][a-z][a-z]\b' | head -1)
    
    rm "$temp_file"
    
    # Validate response (should be 3 letters)
    if [[ "$ai_response" =~ ^[a-z]{3}$ ]]; then
        echo "$ai_response"
        return 0
    else
        echo "eng"
        return 1
    fi
}

# Function to calculate OCR quality score with AI word quality analysis
calculate_quality_score() {
    local text_file="$1"
    
    if [[ ! -f "$text_file" ]]; then
        echo "0"
        return
    fi
    
    # Check if file has content
    local file_size=$(wc -c < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    if [[ $file_size -eq 0 ]]; then
        echo "0"
        return
    fi
    
    # Basic metrics
    local word_count=$(wc -w < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    local line_count=$(wc -l < "$text_file" 2>/dev/null | tr -d ' ' || echo "1")
    local char_count=$(wc -c < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    
    # Get AI word quality assessment
    echo -n "📊 Analyzing word quality with AI... "
    local word_quality=$(analyze_word_quality "$text_file")
    echo "$word_quality%"
    
    # Calculate word score with quality weighting
    local word_score=0
    if [[ $word_count -gt 0 ]]; then
        # Base word score
        local base_word_score=$((word_count * 2))
        if [[ $base_word_score -gt 100 ]]; then base_word_score=100; fi
        
        # Apply quality multiplier (word_quality is 0-100, convert to 0.0-1.0)
        word_score=$((base_word_score * word_quality / 100))
    fi
    
    # Line structure score
    local line_score=0
    if [[ $line_count -gt 0 ]]; then
        line_score=$((line_count * 3))
        if [[ $line_score -gt 50 ]]; then line_score=50; fi
    fi
    
    # Character density score (reasonable density indicates good structure)
    if [[ $line_count -eq 0 ]]; then line_count=1; fi
    local char_density=$((char_count / line_count))
    local density_score=0
    if [[ $char_density -gt 10 && $char_density -lt 200 ]]; then
        density_score=30
    elif [[ $char_density -gt 5 ]]; then
        density_score=15
    fi
    
    # Calculate final score
    local final_score=$((word_score + line_score + density_score))
    
    echo "$final_score"
}

# Function to calculate quality score with detailed breakdown
calculate_quality_score_debug() {
    local text_file="$1"
    
    if [[ ! -f "$text_file" ]]; then
        echo "0"
        echo "0"
        echo "❌ No file"
        return
    fi
    
    # Check if file has content
    local file_size=$(wc -c < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    if [[ $file_size -eq 0 ]]; then
        echo "0"
        echo "0"  
        echo "❌ Empty file"
        return
    fi
    
    # Get basic metrics
    local word_count=$(wc -w < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    local line_count=$(wc -l < "$text_file" 2>/dev/null | tr -d ' ' || echo "1")
    local char_count=$(wc -c < "$text_file" 2>/dev/null | tr -d ' ' || echo "0")
    
    # 1. Word Score (max 100)
    local word_score=0
    if [[ $word_count -gt 0 ]]; then
        word_score=$((word_count * 2))
        if [[ $word_score -gt 100 ]]; then word_score=100; fi
    fi
    
    # 2. Line Score (max 50)
    local line_score=0
    if [[ $line_count -gt 0 ]]; then
        line_score=$((line_count * 3))
        if [[ $line_score -gt 50 ]]; then line_score=50; fi
    fi
    
    # 3. Character Density Score (max 30)
    if [[ $line_count -eq 0 ]]; then line_count=1; fi
    local char_density=$((char_count / line_count))
    local density_score=0
    if [[ $char_density -gt 10 && $char_density -lt 200 ]]; then
        density_score=30
    elif [[ $char_density -gt 5 ]]; then
        density_score=15
    fi
    
    # Calculate final score
    local final_score=$((word_score + line_score + density_score))
    
    # Output format: score, word_count, detailed breakdown
