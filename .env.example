# ~/chat/.env — per-machine, personal config. NOT committed (gitignored).
# Copy this file to ".env" and fill in your own values:
#     cp .env.example .env
# lib_chat.sh sources it automatically before applying defaults.

# --- Web search (/web) ---
# Your SearXNG endpoint(s). One URL, or several (comma-separated) to
# round-robin across them — each is a different source IP, so N instances
# ≈ N× the rate-limit budget (good for heavy batch jobs). Leave blank to
# keep /web disabled.
# export SEARXNG_URL="https://your-searxng.example.com/searx"     # single
# export SEARXNG_URLS="http://localhost:8890, https://your-searxng.example.com/searx"  # round-robin
#
# Optional tuning:
# export SEARXNG_COOLDOWN=60          # seconds to park an endpoint after a 429
# export SEARXNG_CONNECT_TIMEOUT=3    # fast failover when one endpoint is down

# Basic-auth credentials, only if your instance is protected.
# export SEARXNG_USER="your-username"
# export SEARXNG_PASS="your-password"

# --- Optional overrides (all have sensible defaults in lib_chat.sh) ---
# export DEFAULT_MODEL="gemma4:26b"       # fallback model (repo default)
# export WEB_ROUTER_MODEL="llama3.2:3b"   # pin the /web triage model
# export WEB_AUTO=0                        # disable /web triage (always search)
