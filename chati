    curr_sess=$(cat "$PREVIOUS_FILE" 2>/dev/null || echo "active")
    local curr_model
    curr_model=$(active_model)
    local prompt_file
    prompt_file=$(current_session_prompt_file)
    local system_prompt_text="Not Set"
    if [[ -f "$prompt_file" && -s "$prompt_file" ]]; then
        system_prompt_text=$(head -c 200 "$prompt_file")
        [[ $(wc -c < "$prompt_file") -gt 200 ]] && system_prompt_text="${system_prompt_text}…"
    fi
    cat << EOF

Current Chati Settings:
==========================
🤖 Model:    $curr_model
🌐 Lang:     $FORCE_LANG
🔎 Web:      $WEB_MODE
🛠️  Agent:    $AGENT_MODE   (when ON: AI may propose shell commands; you approve each)
🗣️  Talk:     $VOICE_MODE (Voice: $DEFAULT_VOICE, Speed: ${SAY_SPEED}x, Colors: $SAY_COLORS)
📅 Session:  $curr_sess
