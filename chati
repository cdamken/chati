# --- /prompt helpers ---

edit_prompt_in_editor() {
    local prompt_file="$1"
    local editor="${EDITOR:-vi}"
    mkdir -p "$(dirname "$prompt_file")"
    if ! command -v "$editor" >/dev/null 2>&1; then
        echo "❌ \$EDITOR ($editor) not found. Set EDITOR to a valid command."
        return 1
    fi
    "$editor" "$prompt_file"
    if [[ -s "$prompt_file" ]]; then
        echo "✅ Session prompt saved ($(wc -c < "$prompt_file" | tr -d ' ') bytes)."
    else
        rm -f "$prompt_file"
        echo "🗑️  Session prompt cleared (empty)."
    fi
}

# --- STARTUP ---

show_version
echo "------------------"

# Auto-start Ollama on launch if it's not already running. Silent if it
# already is; just informational otherwise.
ensure_ollama_running() {
    if ollama_running; then return 0; fi
    if ! command -v ollama >/dev/null 2>&1; then
        echo "⚠️  ollama binary not found in PATH. Install it: brew install ollama" >&2
        return 1
    fi
    echo "🚀 Starting 'ollama serve' (logs: ~/logs/ollama.log)..."
    mkdir -p "$HOME/logs"
    nohup ollama serve >"$HOME/logs/ollama.log" 2>&1 &
    # Wait up to ~10s for the API to come up.
    local i
    for i in {1..10}; do
        sleep 1
        if ollama_running; then
            echo "   ✅ Ollama is ready."
            return 0
        fi
    done
    echo "   ⚠️  Ollama didn't become ready in 10s. Check ~/logs/ollama.log" >&2
    return 1
}

ensure_ollama_running

# Guard against a STALE explicit selection. active_model() returns a usable
# model when nothing is selected (empty/missing file), but it honors an
# explicit .active_ollama_model.txt verbatim by design — so a model that was
# selected and later removed (`ollama rm`) would otherwise make every chat
# turn fail with "model 'X' not found". Here, at startup only, if the selected
# model isn't installed while others are, switch to an installed one, persist
# it, and say so. No-op when the model is present or Ollama isn't reachable.
ensure_valid_model() {
    ollama_running || return 0
    local want installed
    want=$(active_model)
    installed=$(ollama list 2>/dev/null | tail -n +2 | awk 'NF{print $1}')
    [[ -z "$installed" ]] && return 0                 # nothing installed → active_model already warned elsewhere
    printf '%s\n' "$installed" | grep -qxF "$want" && return 0
    local pick
    pick=$(printf '%s\n' "$installed" | head -1)
    printf '%s\n' "$pick" > "$ACTIVE_MODEL_FILE"
    echo "⚠️  Selected model '$want' is not installed — switched to '$pick'."
    echo "    Change it anytime with /model, or install the original:"
    echo "      ollama pull $want"
}

ensure_valid_model

show_settings
echo "Type /h for help | /bye to exit."

while true; do
    # Recover gracefully if the active session file was deleted.
    curr_sess=$(cat "$PREVIOUS_FILE" 2>/dev/null)
    if [[ -z "$curr_sess" || ! -f "$HISTORY_DIR/$curr_sess" ]]; then
        echo "⚠️  Current session missing. Starting a new one..."
        "$MOLA_CMD" new > /dev/null
    fi

    read -e -rp "> " msg
    [[ -z "$msg" ]] && continue
    history -s "$msg"   # in-memory only; trap flushes on exit

    if [[ "$msg" == /* ]]; then
        cmd_name="${msg%% *}"
        if [[ "$msg" == *" "* ]]; then
            cmd_args="${msg#* }"
        else
            cmd_args=""
        fi

        case "$cmd_name" in
            /bye|/exit|/quit|/q)
                "$MOLA_CMD" save > /dev/null
                echo "Goodbye!"
                exit 0 ;;
            /h|/help|/\?) show_help ;;
            /settings)   show_settings ;;
            /prompt)
                prompt_file=$(current_session_prompt_file)
                if [[ -z "$cmd_args" ]]; then
                    if [[ -f "$prompt_file" && -s "$prompt_file" ]]; then
                        echo "Current System Prompt ($(basename "$prompt_file")):"
                        echo "-----"
                        cat "$prompt_file"
                        echo "-----"
                    else
                        echo "No System Prompt set for this session."
                        echo "Tip: /prompt <text>  or  /prompt -e  (opens \$EDITOR)"
                    fi
                elif [[ "$cmd_args" == "-e" ]]; then
                    edit_prompt_in_editor "$prompt_file"
                elif [[ "$cmd_args" == '""' ]]; then
                    rm -f "$prompt_file"
                    echo "🗑️  System prompt cleared."
                else
                    mkdir -p "$(dirname "$prompt_file")"
                    echo "$cmd_args" > "$prompt_file"
                    echo "✅ System prompt set."
                fi
                ;;
            /sessions)   "$MOLA_CMD" list ;;
            /new)        "$MOLA_CMD" new "$cmd_args" ;;
            /switch)     "$MOLA_CMD" switch "$cmd_args" ;;
            /back)       "$MOLA_CMD" back ;;
            # $cmd_args is left unquoted on purpose so "3 new_name" splits
            # into two args — but disable globbing first (set -f) so a
            # name like "*" isn't expanded against the cwd, then restore.
            /rename)     set -f; "$MOLA_CMD" rename $cmd_args; set +f ;;
            /autorename) set -f; "$MOLA_CMD" autorename $cmd_args; set +f ;;
            /delete)     "$MOLA_CMD" delete "$cmd_args" ;;
            /file|/f)
                # Try the whole argument as a path first so files with
                # spaces work when no instruction follows; fall back to
                # splitting on the first space (file + instruction).
                f_path=$(expand_path "$cmd_args")
                if [[ -f "$f_path" ]]; then
                    macro_fola "$f_path" ""
                else
                    read -r f_file f_instruction <<< "$cmd_args"
                    f_path=$(expand_path "$f_file")
                    macro_fola "$f_path" "$f_instruction"
                fi
                ;;
            /batch|/s)   macro_sola "$cmd_args" ;;
            /talk|/t)
                if [[ "$VOICE_MODE" == "ON" ]]; then VOICE_MODE="OFF"; else VOICE_MODE="ON"; fi
                echo "🗣️  Auto-Voice: $VOICE_MODE" ;;
            /colors)
                if [[ -n "$cmd_args" ]]; then
                    # Whitelist the input — say --interactive=COLORS expects
                    # exactly "fg/bg" with both names from a fixed palette.
                    # Anything else risks breaking the say invocation when
                    # the variable is expanded.
                    if [[ "$cmd_args" =~ ^[a-z]+/[a-z]+$ ]]; then
                        SAY_COLORS="$cmd_args"
                        echo "🎨 Speech colors set to: $SAY_COLORS"
                    else
                        echo "❌ Invalid format. Use foreground/background, e.g. white/green"
                    fi
                else
                    echo "🎨 Current speech colors: $SAY_COLORS"
                    echo "Available: black, red, green, yellow, blue, magenta, cyan, white"
                    echo "Usage: /colors foreground/background"
                fi
                ;;
            /ocr)
                if [[ -n "$cmd_args" ]]; then
                    macro_ocr "$cmd_args"
                else
                    echo "❌ Provide a file, folder, or glob. e.g. /ocr ~/Downloads/scan.pdf"
                fi
                ;;
            /url)
                if [[ -n "$cmd_args" ]]; then
                    echo "🌐 Fetching $cmd_args..."
                    URL_RESULTS=$(fetch_url "$cmd_args")
                    if [[ "$URL_RESULTS" == "Error"* ]]; then
                        echo "❌ $URL_RESULTS"
                    else
                        send_and_capture "Summarize and answer questions: $URL_RESULTS"
                    fi
                else
                    echo "❌ Provide URL."
                fi
                ;;
            /agent|/a)
                if [[ "$AGENT_MODE" == "ON" ]]; then
                    AGENT_MODE="OFF"
                    echo "🛠️  Agent Mode: OFF — AI can no longer run shell commands."
                else
                    AGENT_MODE="ON"
                    echo "🛠️  Agent Mode: ON — AI may now propose shell commands on your Mac."
                    echo "    Each command will ask 'Execute? (y/N)' before running."
                fi ;;
            /web|/w)
                if [[ "$WEB_MODE" == "ON" ]]; then
                    WEB_MODE="OFF"
                    echo "🌐 Web Search: OFF"
                else
                    # SearXNG is external — only enable /web if it actually
                    # answers, so we never pretend to have internet.
                    echo "🌐 Checking web search backend(s)..." >&2
                    web_reason=$(web_search_available 2>&1)
                    if [[ $? -eq 0 ]]; then
                        WEB_MODE="ON"
                        echo "🌐 Web Search: ON"
                        # Show which endpoints are live (round-robins over them).
                        [[ -n "$web_reason" ]] && echo "$web_reason"
                    else
                        WEB_MODE="OFF"
                        echo "🚫 Web search unavailable:"
                        echo "$web_reason"
                        echo "   Staying OFF. Set SEARXNG_URLS (or run a local SearXNG); see installer/SEARXNG_SETUP.md."
                    fi
                fi ;;
            /speed)
                if [[ -n "$cmd_args" ]]; then
                    if [[ "$cmd_args" =~ ^[0-9]*\.?[0-9]+$ ]]; then
                        SAY_SPEED="$cmd_args"
                        update_say_rate
                        echo "🗣️  Speech speed set to: ${SAY_SPEED}x ($SAY_RATE wpm)"
                    else
                        echo "❌ Invalid speed. Use a multiplier (e.g., /speed 1.5)."
                    fi
                else
                    echo "🗣️  Current speech speed: ${SAY_SPEED}x ($SAY_RATE wpm)"
                fi
                ;;
            /model)
                if [[ -n "$cmd_args" ]]; then
                    "$OLA_MODEL_CMD" set "$cmd_args"
                else
                    "$OLA_MODEL_CMD" list
                    # Interactive pick: listing alone used to leave people
                    # typing a bare "1" on the next line, which the REPL then
                    # sent as a chat message to the (maybe-missing) default
                    # model. Prompt for the choice right here instead.
                    read -e -rp "Select a model number or name (Enter to cancel): " model_sel
                    [[ -n "$model_sel" ]] && "$OLA_MODEL_CMD" set "$model_sel"
                fi ;;
            /lang)
                if [[ -z "$cmd_args" ]]; then
                    echo "🌐 Supported LLM response language codes:"
                    echo "${VALID_LANG_CODES[*]}"
                    echo "Current: $FORCE_LANG"
                    echo "(use /voice to set the TTS voice)"
                else
                    arg_lower=$(echo "$cmd_args" | tr '[:upper:]' '[:lower:]')
                    if [[ " ${VALID_LANG_CODES[*]} " =~ \ ${arg_lower}\  ]]; then
                        FORCE_LANG="$arg_lower"
                        echo "🌐 LLM response language set to: $FORCE_LANG"
                    else
                        echo "❌ Unknown language code: $cmd_args"
                        echo "Valid: ${VALID_LANG_CODES[*]}"
                    fi
                fi
                ;;
            /voice)
                if [[ -z "$cmd_args" ]]; then
                    echo "🗣️  Available macOS voices:"
                    say -v "?"
                    echo ""
                    echo "Current: $DEFAULT_VOICE  (AUTO = pick based on output language)"
                else
                    if [[ "$cmd_args" == "auto" || "$cmd_args" == "AUTO" ]]; then
                        DEFAULT_VOICE="AUTO"
                    else
                        DEFAULT_VOICE="$cmd_args"
                    fi
                    echo "🗣️  Voice set to: $DEFAULT_VOICE"
                fi
                ;;
            *)       echo "❓ Unknown command: $cmd_name." ;;
        esac
        continue
    fi

    # --- Non-command: build the message and send it. ---

    # Keep the raw question for conversation memory (augment_message
    # rewraps $msg with research notes; we want the clean text).
    raw_user_msg="$msg"

    msg=$(augment_message "$msg")

    # Sync the agent capability instruction with the current /a toggle.
    # When ON, ola's payload builder reads OLA_EXTRA_SYSTEM and adds it
    # as a real role:system message just before the user turn (see
    # agent_capability_prompt for the full text and rationale).
    if [[ "$AGENT_MODE" == "ON" ]]; then
        export OLA_EXTRA_SYSTEM
        OLA_EXTRA_SYSTEM=$(agent_capability_prompt)
    else
        unset OLA_EXTRA_SYSTEM
    fi

    while true; do
        send_and_capture "$msg"

        # Autonomous tool-use loop.
        if [[ "$AGENT_MODE" == "ON" ]] && agent_cmd=$(extract_exec_cmd "$LAST_RESPONSE"); then
            echo "🐚 AI Action: $agent_cmd"
            # Deny by default: ONLY an explicit y/Y runs the command.
            # Enter, "no", a fat-finger, anything else → cancel. The old
            # gate ran on everything except exactly n/N, so a reflex Enter
            # over [EXEC: rm -rf ...] would have executed it.
            read -rp "✅ Execute? (y/N): " confirm
            if agent_confirmed "$confirm"; then
                # </dev/null: don't let the command read the REPL's stdin
                # (an interactive tool in $agent_cmd would otherwise eat
                # the user's next prompt / hang the loop).
                agent_output=$(bash -c "$agent_cmd" </dev/null 2>&1)
                agent_exit=$?
                if [[ -z "$agent_output" ]]; then
                    if (( agent_exit == 0 )); then
                        echo "📄 Output: (no output, exit=0 — command succeeded)"
                    else
                        echo "📄 Output: (no output, exit=$agent_exit — command failed)"
                    fi
                else
                    echo "📄 Output:"
                    echo "$agent_output"
                    echo "(exit=$agent_exit)"
                fi
                msg="[COMMAND]: $agent_cmd
[EXIT]: $agent_exit
[OUTPUT]:
${agent_output:-(no output)}

Interpret the exit code: 0 means the command succeeded; non-zero means it failed and OUTPUT (if any) is the error message. Do NOT claim success when exit is non-zero."
            else
                echo "🚫 Cancelled (not executed)."
                msg="User denied execution of: $agent_cmd"
            fi
            echo "--- (Autonomous Turn) ---"
        else
            break
        fi
    done

    # Remember this turn (raw question + trimmed answer) so the next /web
    # query can resolve references like "those"/"it" against it. Kept in
    # memory only — the on-disk history is bloated with research wrappers.
    # Last ~6 turns is plenty of context without ballooning the prompt.
    _RECENT_TURNS=$(printf '%suser: %s\nassistant: %s\n' \
        "${_RECENT_TURNS:-}" "$raw_user_msg" "$(printf '%s' "${LAST_RESPONSE:0:500}" | tr '\n' ' ')" \
        | tail -n 12)

    echo "---"
done
